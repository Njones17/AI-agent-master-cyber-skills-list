{
  "mcpServers": {
    "nmap": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "--cap-add=NET_RAW", "--cap-add=NET_ADMIN", "nmap-mcp:latest"]
    },
    "masscan": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "--cap-add=NET_RAW", "--cap-add=NET_ADMIN", "masscan-mcp:latest"]
    },
    "whatweb": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "whatweb-mcp:latest"]
    },
    "nuclei": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "nuclei-mcp:latest"]
    },
    "sqlmap": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "sqlmap-mcp:latest"]
    },
    "ffuf": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "ffuf-mcp:latest"]
    },
    "waybackurls": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "waybackurls-mcp:latest"]
    },
    "radare2": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/path/to/binaries:/samples:ro", "radare2-mcp:latest"]
    },
    "binwalk": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/path/to/firmware:/samples:ro", "binwalk-mcp:latest"]
    },
    "yara": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/path/to/samples:/samples:ro", "yara-mcp:latest"]
    },
    "capa": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/path/to/binaries:/samples:ro", "capa-mcp:latest"]
    },
    "trivy": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/var/run/docker.sock:/var/run/docker.sock:ro", "trivy-mcp:latest"]
    },
    "prowler": {
      "command": "docker",
      "args": ["run", "-i", "--rm",
        "-e", "AWS_ACCESS_KEY_ID",
        "-e", "AWS_SECRET_ACCESS_KEY",
        "-e", "AWS_SESSION_TOKEN",
        "prowler-mcp:latest"
      ]
    },
    "gitleaks": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/path/to/repos:/app/target:ro", "gitleaks-mcp:latest"]
    },
    "semgrep": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-v", "/path/to/code:/app/target:ro", "semgrep-mcp:latest"]
    },
    "searchsploit": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "searchsploit-mcp:latest"]
    },
    "bloodhound": {
      "command": "docker",
      "args": ["run", "-i", "--rm",
        "-e", "BLOODHOUND_URL",
        "-e", "BLOODHOUND_TOKEN",
        "bloodhound-mcp:latest"
      ]
    }
  }
}
