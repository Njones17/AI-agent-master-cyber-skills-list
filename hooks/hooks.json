{
  "description": "Master Cybersecurity Skills — Security automation hooks. Scans for secrets, checks dependencies, audits code for OWASP issues, guards scope boundaries, warns on destructive commands, and captures evidence.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/scan-secrets.sh",
            "timeout": 30,
            "statusMessage": "Scanning for secrets...",
            "async": true
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-deps.sh",
            "timeout": 60,
            "statusMessage": "Checking dependencies for vulnerabilities...",
            "async": true
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/owasp-check.sh",
            "timeout": 45,
            "statusMessage": "Running OWASP security checks...",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/scope-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking scope..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/danger-check.sh",
            "timeout": 5,
            "statusMessage": "Safety check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture-evidence.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
